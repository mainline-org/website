---
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeCopy, localizedPath, type Locale } from "../i18n";
import { loadHubSnapshot } from "../hubSnapshot";
import { organizationJsonLd, softwareJsonLd, webPageJsonLd, webSiteJsonLd } from "../structuredData";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = homeCopy[locale];
const hubSnapshot = loadHubSnapshot();
const dateLocales: Record<Locale, string> = {
  en: "en-US",
  zh: "zh-CN",
  es: "es-ES",
};
const generatedAt = hubSnapshot
  ? new Intl.DateTimeFormat(dateLocales[locale], {
      dateStyle: "medium",
      timeStyle: "short",
      timeZone: "UTC",
    }).format(new Date(hubSnapshot.generatedAt))
  : "";
const formatInsight = (template: string, count: number) => template.replace("{count}", String(count));
const hubInsights = hubSnapshot
  ? [
      {
        label: t.selfHub.insights.decisions.label,
        text: formatInsight(t.selfHub.insights.decisions.text, hubSnapshot.mergedIntents),
      },
      {
        label: t.selfHub.insights.constraints.label,
        text: formatInsight(t.selfHub.insights.constraints.text, hubSnapshot.riskIntents),
      },
      {
        label: t.selfHub.insights.work.label,
        text: formatInsight(t.selfHub.insights.work.text, hubSnapshot.proposedIntents),
      },
    ]
  : [];
const pageJsonLd = webPageJsonLd({
  title: t.metaTitle,
  description: t.metaDescription,
  path: localizedPath(locale, "/"),
});
---

<BaseLayout
  locale={locale}
  pagePath="/"
  title={t.metaTitle}
  description={t.metaDescription}
  ogTitle={t.ogTitle}
  ogDescription={t.ogDescription}
  twitterTitle={t.twitterTitle}
  twitterDescription={t.twitterDescription}
  jsonLd={[organizationJsonLd, webSiteJsonLd, softwareJsonLd, pageJsonLd]}
>
  <section class="hero shell">
    <div class="hero-copy">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1>{t.heading}</h1>
      <p class="hero-lede">{t.lede}</p>
      <div class="hero-actions">
        <a class="button primary" href={localizedPath(locale, "/docs/")}>{t.primaryCta}</a>
        <a class="button secondary" href={localizedPath(locale, "/blog/why-coding-agents-need-repo-memory/")}>{t.secondaryCta}</a>
      </div>
      <div class="install-strip" aria-label={t.installAria}>
        <span>{t.install}</span>
        <code>curl -fsSL https://raw.githubusercontent.com/mainline-org/mainline/main/install.sh | bash</code>
      </div>
    </div>
    <div class="hero-visual" aria-label={t.visualAria}>
      <div class="logo-showcase" aria-hidden="true">
        <img src="/mainline_logo.svg" alt="" width="148" height="148" loading="eager" decoding="async" />
      </div>
      <div class="terminal-card">
        <div class="window-bar">
          <span></span><span></span><span></span>
        </div>
        <pre><code>{t.terminalSnippet}</code></pre>
      </div>
      <div class="intent-card">
        <p>{t.intentCard.label}</p>
        <h2>{t.intentCard.title}</h2>
        <dl>
          {t.intentCard.rows.map(([term, description]) => (
            <div><dt>{term}</dt><dd>{description}</dd></div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <section class="proof-band">
    <div class="shell proof-grid">
      {t.metrics.map(([metric, label]) => (
        <div>
          <span class="metric">{metric}</span>
          <p>{label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section self-hub-band" aria-labelledby="self-hub-heading">
    <div class="shell self-hub">
      <div class="self-hub-copy">
        <p class="eyebrow">{t.selfHub.eyebrow}</p>
        <h2 id="self-hub-heading">{t.selfHub.heading}</h2>
        <p>{t.selfHub.text}</p>
        <div class="hero-actions">
          <a class="button primary" href="/hub/">{t.selfHub.cta}</a>
        </div>
      </div>
      <div class="self-hub-panel" aria-label={t.selfHub.aria}>
        {hubSnapshot ? (
          <>
            <div class="self-hub-status">
              <span>{t.selfHub.live}</span>
              <time datetime={hubSnapshot.generatedAt}>{t.selfHub.updated} {generatedAt} UTC</time>
            </div>
            <div class="self-hub-stats">
              <div><strong>{hubSnapshot.totalIntents}</strong><span>{t.selfHub.stats.intents}</span></div>
              <div><strong>{hubSnapshot.proposedIntents}</strong><span>{t.selfHub.stats.proposed}</span></div>
              <div><strong>{hubSnapshot.mergedIntents}</strong><span>{t.selfHub.stats.merged}</span></div>
              <div><strong>{hubSnapshot.riskIntents}</strong><span>{t.selfHub.stats.constraints}</span></div>
              <div><strong>{hubSnapshot.fileCount}</strong><span>{t.selfHub.stats.files}</span></div>
              <div><strong>{hubSnapshot.actorCount}</strong><span>{t.selfHub.stats.actors}</span></div>
            </div>
            <div class="self-hub-insights">
              <h3>{t.selfHub.insights.heading}</h3>
              <div>
                {hubInsights.map((item) => (
                  <article>
                    <span>{item.label}</span>
                    <p>{item.text}</p>
                  </article>
                ))}
              </div>
            </div>
          </>
        ) : (
          <div class="self-hub-empty">
            <span>{t.selfHub.pendingLabel}</span>
            <p>{t.selfHub.pendingText}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="section shell two-column">
    <div>
      <p class="eyebrow">{t.wedge.eyebrow}</p>
      <h2>{t.wedge.heading}</h2>
    </div>
    <div class="rich-text">
      {t.wedge.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="section shell split-cards compact-cards">
    {t.wedge.cards.map(([heading, body]) => (
      <article>
        <h2>{heading}</h2>
        <p>{body}</p>
      </article>
    ))}
  </section>

  <section class="section shell two-column">
    <div>
      <p class="eyebrow">{t.failure.eyebrow}</p>
      <h2>{t.failure.heading}</h2>
    </div>
    <div class="rich-text">
      {t.failure.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="section shell feature-grid">
    {t.features.map(([heading, body], index) => (
      <article>
        <span class="feature-index">{String(index + 1).padStart(2, "0")}</span>
        <h3>{heading}</h3>
        <p>{body}</p>
      </article>
    ))}
  </section>

  <section class="section shell workflow">
    <div>
      <p class="eyebrow">{t.workflow.eyebrow}</p>
      <h2>{t.workflow.heading}</h2>
    </div>
    <ol>
      {t.workflow.steps.map(([command, label]) => (
        <li><code>{command}</code><span>{label}</span></li>
      ))}
    </ol>
  </section>

  <section class="section shell split-cards">
    {t.audiences.map(([heading, body]) => (
      <article>
        <h2>{heading}</h2>
        <p>{body}</p>
      </article>
    ))}
  </section>

  <section class="section shell two-column">
    <div>
      <p class="eyebrow">{t.choices.eyebrow}</p>
      <h2>{t.choices.heading}</h2>
    </div>
    <div class="rich-text">
      <ul class="choice-list">
        {t.choices.cards.map(([heading, body]) => (
          <li><strong>{heading}</strong><span>{body}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section shell final-cta">
    <p class="eyebrow">{t.cta.eyebrow}</p>
    <h2>{t.cta.heading}</h2>
    <p>{t.cta.text}</p>
    <div class="hero-actions">
      <a class="button primary" href="https://github.com/mainline-org/mainline">{t.cta.github}</a>
      <a class="button secondary" href="/design-partners/">{t.cta.designPartner}</a>
    </div>
  </section>
</BaseLayout>
