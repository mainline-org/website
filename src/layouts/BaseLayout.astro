---
import "../styles/global.css";
import {
  defaultLocale,
  localeCodes,
  locales,
  localizedPath,
  uiCopy,
  type Locale,
} from "../i18n";

interface Props {
  title?: string;
  description?: string;
  keywords?: string[] | string;
  robots?: string;
  author?: string;
  canonicalPath?: string;
  locale?: Locale;
  pagePath?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterSite?: string;
  twitterCreator?: string;
  availableLocales?: Locale[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Mainline - Repo memory for coding agents",
  description = "Mainline gives AI coding agents Git-native repo memory before edits: prior decisions, abandoned approaches, risks, and reviewer constraints.",
  keywords = [
    "Mainline",
    "coding agent memory",
    "repo memory for AI agents",
    "Git-native memory",
    "engineering intent memory",
    "agent context protocol",
    "AI coding agents",
    "AI PR review",
    "intent records",
    "developer tools",
  ],
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
  author = "Mainline maintainers",
  locale = defaultLocale,
  pagePath = Astro.url.pathname.replace(/^\/(zh|es)(?=\/|$)/, "") || "/",
  canonicalPath = localizedPath(locale, pagePath),
  ogImage = "/og-image.png",
  ogTitle,
  ogDescription,
  twitterTitle,
  twitterDescription,
  twitterSite = "@mainline_sh",
  twitterCreator = "@mainline_sh",
  availableLocales = [...localeCodes],
  jsonLd = [],
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://mainline.sh";
const canonical = new URL(canonicalPath, site).toString();
const imageUrl = new URL(ogImage, site).toString();
const pageTitle = title.includes("Mainline") ? title : `${title} - Mainline`;
const keywordContent = Array.isArray(keywords) ? keywords.join(", ") : keywords;
const openGraphTitle = ogTitle ?? pageTitle;
const openGraphDescription = ogDescription ?? description;
const xTitle = twitterTitle ?? pageTitle;
const xDescription = twitterDescription ?? description;
const ui = uiCopy[locale];
const htmlLang = locales[locale].htmlLang;
const ogLocales: Record<Locale, string> = {
  en: "en_US",
  zh: "zh_CN",
  es: "es_ES",
};
const languageLinks = availableLocales.map((code) => ({
  code,
  label: locales[code].shortLabel,
  href: localizedPath(code, pagePath),
  hreflang: locales[code].hreflang,
}));
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordContent} />
    <meta name="robots" content={robots} />
    <meta name="author" content={author} />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mainline" />
    <meta property="og:title" content={openGraphTitle} />
    <meta property="og:description" content={openGraphDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {availableLocales.filter((code) => code !== locale).map((code) => (
      <meta property="og:locale:alternate" content={ogLocales[code]} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterSite} />
    <meta name="twitter:creator" content={twitterCreator} />
    <meta name="twitter:title" content={xTitle} />
    <meta name="twitter:description" content={xDescription} />
    <meta name="twitter:image" content={imageUrl} />
    {languageLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={new URL(link.href, site).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(localizedPath(defaultLocale, pagePath), site).toString()} />
    {jsonLdItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#content">{ui.skip}</a>
    <header class="site-header">
      <nav class="nav shell" aria-label={ui.primaryNav}>
        <a class="brand" href={localizedPath(locale, "/")} aria-label={ui.homeLabel}>
          <span class="brand-mark" aria-hidden="true">
            <img src="/mainline_logo.svg" alt="" width="34" height="34" decoding="async" />
          </span>
          <span>Mainline</span>
        </a>
        <div class="nav-links">
          <a href={localizedPath(locale, "/docs/")}>{ui.nav.docs}</a>
          <a href={localizedPath(locale, "/spec/")}>{ui.nav.spec}</a>
          <a href={localizedPath(locale, "/blog/")}>{ui.nav.blog}</a>
          <a href={localizedPath(locale, "/compare/rag/")}>{ui.nav.compare}</a>
        </div>
        <div class="nav-actions">
          <div class="language-switcher" aria-label={ui.language}>
            {languageLinks.map((link) => (
              <a
                href={link.href}
                hreflang={link.hreflang}
                class:list={[link.code === locale && "active"]}
              >
                {link.label}
              </a>
            ))}
          </div>
          <a class="nav-cta" href="https://github.com/mainline-org/mainline">{ui.github}</a>
        </div>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <div>
          <a class="brand footer-brand" href={localizedPath(locale, "/")}>
            <span class="brand-mark" aria-hidden="true">
              <img src="/mainline_logo.svg" alt="" width="34" height="34" decoding="async" />
            </span>
            <span>Mainline</span>
          </a>
          <p>{ui.footer.tagline}</p>
        </div>
        <div>
          <h2>{ui.footer.product}</h2>
          <a href={localizedPath(locale, "/docs/")}>{ui.nav.docs}</a>
          <a href={localizedPath(locale, "/spec/")}>{ui.nav.spec}</a>
          <a href={localizedPath(locale, "/install/")}>{ui.footer.install}</a>
          <a href="/eval/">{ui.footer.eval}</a>
          <a href="/pricing/">{ui.footer.pricing}</a>
          <a href={localizedPath(locale, "/compare/session-memory/")}>{ui.footer.sessionMemory}</a>
        </div>
        <div>
          <h2>{ui.footer.writing}</h2>
          <a href={localizedPath(locale, "/blog/")}>{ui.nav.blog}</a>
          <a href="/changelog/">{ui.footer.changelog}</a>
          <a href={localizedPath(locale, "/blog/why-coding-agents-need-repo-memory/")}>{ui.footer.repoMemoryEssay}</a>
          <a href="/glossary/">{ui.footer.glossary}</a>
          <a href="/design-partners/">{ui.footer.designPartners}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
