---
import BaseLayout from "./BaseLayout.astro";
import { blogCopy, localizedPath, type Locale } from "../i18n";

const {
  title,
  metaTitle,
  subtitle,
  description,
  publishDate,
  locale = "en",
  pagePath = "/blog/why-coding-agents-need-repo-memory/",
} = Astro.props.frontmatter;

const currentLocale = locale as Locale;
const blog = blogCopy[currentLocale];
const canonicalPath = localizedPath(currentLocale, pagePath);
---

<BaseLayout
  title={metaTitle ?? title}
  description={description ?? subtitle}
  locale={currentLocale}
  pagePath={pagePath}
  canonicalPath={canonicalPath}
>
  <article class="article shell">
    <header class="article-header">
      <a class="eyebrow" href={localizedPath(currentLocale, "/blog/")}>{blog.eyebrow}</a>
      <h1>{title}</h1>
      {subtitle && <p class="article-subtitle">{subtitle}</p>}
      {publishDate && <time datetime={publishDate}>{publishDate}</time>}
    </header>
    <div class="article-body">
      <slot />
    </div>
  </article>
</BaseLayout>
