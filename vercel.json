{
  "buildCommand": "npm run build:vercel",
  "ignoreCommand": "test \"${VERCEL_GIT_COMMIT_REF#_mainline/}\" != \"$VERCEL_GIT_COMMIT_REF\"",
  "outputDirectory": "dist",
  "framework": "astro",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "redirects": [
    { "source": "/comparisons/mainline-vs-rag", "destination": "/compare/rag/", "permanent": true },
    { "source": "/comparisons/mainline-vs-rag/", "destination": "/compare/rag/", "permanent": true },
    { "source": "/comparisons/mainline-vs-session-memory", "destination": "/compare/session-memory/", "permanent": true },
    { "source": "/comparisons/mainline-vs-session-memory/", "destination": "/compare/session-memory/", "permanent": true },
    { "source": "/docs/copilot", "destination": "/docs/github-copilot/", "permanent": true },
    { "source": "/docs/copilot/", "destination": "/docs/github-copilot/", "permanent": true },
    { "source": "/zh/comparisons/mainline-vs-rag", "destination": "/zh/compare/rag/", "permanent": true },
    { "source": "/zh/comparisons/mainline-vs-rag/", "destination": "/zh/compare/rag/", "permanent": true },
    { "source": "/zh/comparisons/mainline-vs-session-memory", "destination": "/zh/compare/session-memory/", "permanent": true },
    { "source": "/zh/comparisons/mainline-vs-session-memory/", "destination": "/zh/compare/session-memory/", "permanent": true },
    { "source": "/es/comparisons/mainline-vs-rag", "destination": "/es/compare/rag/", "permanent": true },
    { "source": "/es/comparisons/mainline-vs-rag/", "destination": "/es/compare/rag/", "permanent": true },
    { "source": "/es/comparisons/mainline-vs-session-memory", "destination": "/es/compare/session-memory/", "permanent": true },
    { "source": "/es/comparisons/mainline-vs-session-memory/", "destination": "/es/compare/session-memory/", "permanent": true }
  ]
}
